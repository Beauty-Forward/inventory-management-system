rules_version = '2';

// IMS Firestore rules — only used by the local emulator. Production
// Firestore is shared with the donation-delivery-app, and that repo's
// firestore.rules is the source of truth in deploy. The IMS app itself
// doesn't write to Firestore directly; the only consumer here is the
// `onDonationRequestWrite` trigger, which runs server-side under admin
// credentials and bypasses rules anyway.
//
// Rules below are deliberately permissive so the local emulator UI lets
// you create test donation_requests docs without auth scaffolding.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
