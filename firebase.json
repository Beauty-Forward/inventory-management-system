{
  "apphosting": {
    "backendId": "inventory-management-system",
    "rootDir": "/",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "functions"
    ]
  },
  "dataconnect": {
    "source": "dataconnect"
  },
  "functions": {
    "source": "../donation-delivery-app/functions"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "dataconnect": {
      "port": 9399
    },
    "functions": {
      "port": 5001
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}
